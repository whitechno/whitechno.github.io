---
layout: null
---
<?xml version="1.0" encoding="utf-8"?>
<feed xmlns="http://www.w3.org/2005/Atom">
  <title>{{ site.title | xml_escape }}</title>
  <subtitle>{{ site.description | xml_escape }}</subtitle>
  <link href="{{ '/feed.xml' | absolute_url }}" rel="self"/>
  <link href="{{ '/' | absolute_url }}"/>
  <id>{{ '/' | absolute_url }}</id>
  <author><name>{{ site.title | xml_escape }}</name></author>
  {%- assign posts = site.pages
     | where_exp: "p", "p.dir contains '/blog/'"
     | where_exp: "p", "p.date"
     | sort: "date" | reverse %}
  <updated>{{ posts.first.date | date_to_xmlschema }}</updated>
  {%- for post in posts %}
  <entry>
    <title>{{ post.title | xml_escape }}</title>
    <link href="{{ post.url | absolute_url }}"/>
    <id>{{ post.url | absolute_url }}</id>
    <published>{{ post.date | date_to_xmlschema }}</published>
    <updated>{{ post.date | date_to_xmlschema }}</updated>
    <summary>{{ post.description | default: site.description | xml_escape }}</summary>
  </entry>
  {%- endfor %}
</feed>
